---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: string;
  publishedDate?: string;
}

const {
  title,
  description = '楓念的个人博客 - 记录代码、技术与二次元生活',
  image = 'https://s1.imagehub.cc/images/2025/12/09/d0630008618c165c9bd3f9469d27dfc2.png',
  canonicalURL = Astro.url.href,
  type = 'website',
  publishedDate,
} = Astro.props as Props;
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />

    <script is:inline>
      try {
        const savedTheme = localStorage.getItem('blog-theme');
        if (savedTheme) {
          document.documentElement.setAttribute('data-theme', savedTheme);
        }
      } catch {
        // Ignore storage access errors.
      }
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="楓念的博客" />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://s1.imagehub.cc" />

    <!-- Favicon (64x64 circular PNG, base64-inlined to avoid an extra HTTP request) -->
    <link rel="icon" type="image/png" href="data:image/png;base64," />
    <link rel="apple-touch-icon" href="https://s1.imagehub.cc/images/2025/12/09/d0630008618c165c9bd3f9469d27dfc2.png" />

    <!-- Structured Data -->
    {publishedDate && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': type === 'article' ? 'Article' : 'WebPage',
        headline: title,
        description,
        image,
        url: canonicalURL,
        ...(type === 'article' ? { datePublished: publishedDate } : {}),
        author: { '@type': 'Person', name: '楓念' }
      })} />
    )}

    <!-- Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@500;600;700&family=JetBrains+Mono:wght@500&display=swap" />

    <title>{title}</title>
  </head>
  <body>
    <!-- Skip to content -->
    <a class="skip-to-content" href="#main-content">跳到主要内容</a>

    <slot />

    <script is:inline>
      const STORAGE_THEME = 'blog-theme';

      const html = document.documentElement;

      function safeGetStorage(key, fallback = '') {
        try {
          const value = localStorage.getItem(key);
          return value === null ? fallback : value;
        } catch {
          return fallback;
        }
      }

      function safeSetStorage(key, value) {
        try {
          localStorage.setItem(key, value);
        } catch {
          // Ignore storage access errors.
        }
      }

      // Apply stored theme immediately to prevent flash
      const savedTheme = safeGetStorage(STORAGE_THEME, 'light');
      html.setAttribute('data-theme', savedTheme);

      window.__blogThemeToggle = function() {
        const current = html.getAttribute('data-theme') || 'light';
        const next = current === 'light' ? 'dark' : 'light';
        html.setAttribute('data-theme', next);
        safeSetStorage(STORAGE_THEME, next);
        return next;
      };

      window.__blogThemeGet = function() {
        return html.getAttribute('data-theme') || 'light';
      };
    </script>
  </body>
</html>
