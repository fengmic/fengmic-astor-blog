---
import '../styles/global.css';
import ThemeToggles from '../components/ThemeToggles.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: string;
  publishedDate?: string;
}

const {
  title,
  description = '楓念的个人博客 - 记录代码、技术与二次元生活',
  image = 'https://s1.imagehub.cc/images/2025/12/09/d0630008618c165c9bd3f9469d27dfc2.png',
  canonicalURL = Astro.url.href,
  type = 'website',
  publishedDate,
} = Astro.props as Props;
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />

    <script is:inline>
      try {
        const savedTheme = localStorage.getItem('blog-theme');
        if (savedTheme) {
          document.documentElement.setAttribute('data-theme', savedTheme);
        }
      } catch {
        // Ignore storage access errors.
      }
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="楓念的博客" />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://s1.imagehub.cc" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="https://s1.imagehub.cc/images/2025/12/09/d0630008618c165c9bd3f9469d27dfc2.png" />
    <link rel="apple-touch-icon" href="https://s1.imagehub.cc/images/2025/12/09/d0630008618c165c9bd3f9469d27dfc2.png" />

    <!-- Structured Data -->
    {publishedDate && (
      <script type="application/ld+json" set:html={`{
        "@context": "https://schema.org",
        "@type": "${type === 'article' ? 'Article' : 'WebPage'}",
        "headline": "${title}",
        "description": "${description}",
        "image": "${image}",
        "url": "${canonicalURL}",
        ${type === 'article' ? `"datePublished": "${publishedDate}",` : ''}
        "author": {
          "@type": "Person",
          "name": "楓念"
        }
      }`} />
    )}

    <!-- Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=ZCOOL+XiaoWei&family=Noto+Sans+SC:wght@400;500;700&family=JetBrains+Mono:wght@500&display=swap" />

    <title>{title}</title>
  </head>
  <body>
    <!-- Skip to content -->
    <a class="skip-to-content" href="#main-content">跳到主要内容</a>

    <slot />

    <!-- Floating toolbar: theme + effects toggles -->
    <ThemeToggles />

    <script is:inline>
      const STORAGE_THEME = 'blog-theme';
      const STORAGE_EFFECT = 'blog-effect';

      const html = document.documentElement;

      function safeGetStorage(key, fallback = '') {
        try {
          const value = localStorage.getItem(key);
          return value === null ? fallback : value;
        } catch {
          return fallback;
        }
      }

      function safeSetStorage(key, value) {
        try {
          localStorage.setItem(key, value);
        } catch {
          // Ignore storage access errors.
        }
      }

      // Apply stored theme immediately to prevent flash
      const savedTheme = safeGetStorage(STORAGE_THEME, 'light');
      html.setAttribute('data-theme', savedTheme);

      // Apply stored effect (sakura only)
      let currentEffect = safeGetStorage(STORAGE_EFFECT, '');
      if (currentEffect !== '' && currentEffect !== 'sakura') {
        currentEffect = '';
      }

      function removeEffects() {
        document.querySelectorAll('.fx-sakura').forEach((el) => {
          if (typeof el.__cleanup === 'function') {
            try {
              el.__cleanup();
            } catch {
              // Ignore cleanup errors.
            }
          }
          el.remove();
        });
      }

      function createSakura() {
        const container = document.createElement('div');
        container.className = 'fx-sakura';
        container.setAttribute('aria-hidden', 'true');

        const canvas = document.createElement('canvas');
        canvas.className = 'fx-sakura-canvas';
        container.appendChild(canvas);
        document.body.appendChild(container);

        const ctx = canvas.getContext('2d');
        if (!ctx) {
          container.remove();
          return;
        }

        const prefersReducedMotion =
          typeof window.matchMedia === 'function' &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const pointer = { x: -9999, y: -9999, active: false };
        const activePetals = [];
        const settledPetals = [];

        const BIN_SIZE = 18;
        let bins = [];
        let width = 0;
        let height = 0;
        let dpr = 1;
        let rafId = 0;

        const TARGET_ACTIVE = prefersReducedMotion ? 14 : 52;
        const MAX_SETTLED = prefersReducedMotion ? 90 : 240;
        const GRAVITY = prefersReducedMotion ? 0.006 : 0.013;
        const DRAG = 0.992;
        const POINTER_RADIUS = prefersReducedMotion ? 76 : 110;
        const POINTER_FORCE = prefersReducedMotion ? 0.2 : 0.45;

        function makePetal(spawnAtTop = true) {
          const size = 7 + Math.random() * 8;
          return {
            x: Math.random() * width,
            y: spawnAtTop ? -24 - Math.random() * height * 0.35 : Math.random() * height * 0.55,
            vx: (Math.random() - 0.5) * 0.6,
            vy: 0.6 + Math.random() * 1.1,
            size,
            alpha: 0.62 + Math.random() * 0.28,
            rot: Math.random() * Math.PI * 2,
            spin: (Math.random() - 0.5) * 0.04,
            sway: 0.25 + Math.random() * 0.9,
            phase: Math.random() * Math.PI * 2,
            color: `hsla(${330 + Math.random() * 16}, ${78 + Math.random() * 12}%, ${76 + Math.random() * 10}%, 1)`,
            settled: false,
          };
        }

        function drawPetal(petal) {
          ctx.save();
          ctx.translate(petal.x, petal.y);
          ctx.rotate(petal.rot);
          ctx.globalAlpha = petal.alpha;

          ctx.fillStyle = petal.color;
          ctx.beginPath();
          ctx.moveTo(0, -petal.size * 0.95);
          ctx.bezierCurveTo(
            petal.size * 0.82,
            -petal.size * 0.5,
            petal.size * 0.86,
            petal.size * 0.62,
            0,
            petal.size,
          );
          ctx.bezierCurveTo(
            -petal.size * 0.86,
            petal.size * 0.62,
            -petal.size * 0.82,
            -petal.size * 0.5,
            0,
            -petal.size * 0.95,
          );
          ctx.fill();

          ctx.fillStyle = 'rgba(255,255,255,0.26)';
          ctx.beginPath();
          ctx.ellipse(
            -petal.size * 0.18,
            -petal.size * 0.14,
            petal.size * 0.2,
            petal.size * 0.11,
            -0.5,
            0,
            Math.PI * 2,
          );
          ctx.fill();

          ctx.restore();
        }

        function settlePetal(petal) {
          const idx = Math.max(0, Math.min(bins.length - 1, Math.floor(petal.x / BIN_SIZE)));
          const depth = bins[idx] || 0;

          bins[idx] = Math.min(depth + 1, 32);
          petal.x = Math.max(petal.size * 0.55, Math.min(width - petal.size * 0.55, petal.x + (Math.random() - 0.5) * 4));
          petal.y = height - petal.size * 0.55 - depth * (petal.size * 0.22 + 1.4);
          petal.vx = 0;
          petal.vy = 0;
          petal.spin *= 0.2;
          petal.alpha = Math.min(0.95, petal.alpha + 0.08);
          petal.settled = true;

          settledPetals.push(petal);
          if (settledPetals.length > MAX_SETTLED) {
            const removed = settledPetals.shift();
            if (removed) {
              const ridx = Math.max(0, Math.min(bins.length - 1, Math.floor(removed.x / BIN_SIZE)));
              bins[ridx] = Math.max(0, bins[ridx] - 1);
            }
          }
        }

        function resize() {
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          width = window.innerWidth;
          height = window.innerHeight;

          canvas.width = Math.max(1, Math.floor(width * dpr));
          canvas.height = Math.max(1, Math.floor(height * dpr));
          canvas.style.width = `${width}px`;
          canvas.style.height = `${height}px`;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

          bins = new Array(Math.max(1, Math.ceil(width / BIN_SIZE))).fill(0);
          settledPetals.length = 0;
        }

        function onPointerMove(event) {
          pointer.x = event.clientX;
          pointer.y = event.clientY;
          pointer.active = true;
        }

        function onPointerLeave() {
          pointer.active = false;
          pointer.x = -9999;
          pointer.y = -9999;
        }

        function loop(time) {
          if (document.hidden) {
            rafId = 0;
            return;
          }

          ctx.clearRect(0, 0, width, height);

          while (activePetals.length < TARGET_ACTIVE) {
            activePetals.push(makePetal(activePetals.length > TARGET_ACTIVE * 0.6));
          }

          for (let i = 0; i < settledPetals.length; i++) {
            const petal = settledPetals[i];
            petal.rot += petal.spin * 0.2;
            drawPetal(petal);
          }

          for (let i = activePetals.length - 1; i >= 0; i--) {
            const petal = activePetals[i];

            petal.vy += GRAVITY;
            petal.vx += Math.sin(time * 0.0014 + petal.phase + petal.y * 0.004) * 0.012 * petal.sway;

            if (pointer.active) {
              const dx = petal.x - pointer.x;
              const dy = petal.y - pointer.y;
              const distance = Math.hypot(dx, dy);

              if (distance > 0.001 && distance < POINTER_RADIUS) {
                const force = (1 - distance / POINTER_RADIUS) * POINTER_FORCE;
                petal.vx += (dx / distance) * force * 2.1;
                petal.vy += (dy / distance) * force * 1.45;
              }
            }

            petal.vx *= DRAG;
            petal.vy *= 0.996;
            petal.x += petal.vx + petal.sway * 0.19;
            petal.y += petal.vy;
            petal.rot += petal.spin + petal.vx * 0.02;

            if (petal.x < -24) petal.x = width + 24;
            if (petal.x > width + 24) petal.x = -24;

            if (petal.y >= height - 4) {
              activePetals.splice(i, 1);
              settlePetal(petal);
              continue;
            }

            drawPetal(petal);
          }

          rafId = window.requestAnimationFrame(loop);
        }

        function onVisibilityChange() {
          if (!document.hidden && rafId === 0) {
            rafId = window.requestAnimationFrame(loop);
          }
        }

        resize();
        for (let i = 0; i < Math.floor(TARGET_ACTIVE * 0.65); i++) {
          activePetals.push(makePetal(false));
        }

        window.addEventListener('resize', resize, { passive: true });
        window.addEventListener('pointermove', onPointerMove, { passive: true });
        window.addEventListener('pointerdown', onPointerMove, { passive: true });
        window.addEventListener('pointerleave', onPointerLeave, { passive: true });
        window.addEventListener('blur', onPointerLeave);
        document.addEventListener('visibilitychange', onVisibilityChange);

        container.__cleanup = () => {
          window.cancelAnimationFrame(rafId);
          window.removeEventListener('resize', resize);
          window.removeEventListener('pointermove', onPointerMove);
          window.removeEventListener('pointerdown', onPointerMove);
          window.removeEventListener('pointerleave', onPointerLeave);
          window.removeEventListener('blur', onPointerLeave);
          document.removeEventListener('visibilitychange', onVisibilityChange);
        };

        rafId = window.requestAnimationFrame(loop);
      }

      function applyEffect(name) {
        removeEffects();
        if (name === 'sakura') createSakura();
      }

      // Initialize effect during browser idle time to reduce page-load contention.
      const scheduleIdle = window.requestIdleCallback
        ? (cb) => window.requestIdleCallback(cb)
        : (cb) => window.setTimeout(cb, 0);
      scheduleIdle(() => {
        if (currentEffect) applyEffect(currentEffect);
      });

      // Expose for the toggle component
      window.__blogEffectCycle = function() {
        const effects = ['', 'sakura'];
        const idx = effects.indexOf(currentEffect);
        const next = effects[(idx + 1) % effects.length];
        currentEffect = next;
        safeSetStorage(STORAGE_EFFECT, currentEffect);
        applyEffect(currentEffect);
        return currentEffect;
      };

      window.__blogEffectGet = function() {
        return currentEffect;
      };

      window.__blogThemeToggle = function() {
        const current = html.getAttribute('data-theme') || 'light';
        const next = current === 'light' ? 'dark' : 'light';
        html.setAttribute('data-theme', next);
        safeSetStorage(STORAGE_THEME, next);
        return next;
      };

      window.__blogThemeGet = function() {
        return html.getAttribute('data-theme') || 'light';
      };
    </script>
  </body>
</html>
