---
import ThemeToggles from './ThemeToggles.astro';

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/home', label: '首页' },
  { href: '/archive', label: '归档' },
  { href: '/album', label: '相册' }
];

function isActive(href: string) {
  if (href === '/home') {
    return currentPath === '/' || currentPath === '/home' || currentPath.startsWith('/home/') || currentPath.startsWith('/post/');
  }
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header class="navbar-wrap" role="banner" transition:persist>
  <nav class="navbar glass-panel" aria-label="主导航">
    <a class="brand" href="/home" aria-label="返回首页">楓念的博客</a>

    <form id="search-form" class="search-form" role="search" aria-label="搜索文章">
      <div class="search-input-wrap">
        <input
          id="search-input"
          type="search"
          placeholder="搜索标题、摘要、标签..."
          aria-label="搜索关键词"
          autocomplete="off"
        />
        <kbd class="search-kbd" aria-hidden="true">/</kbd>
      </div>
      <button type="submit" aria-label="执行搜索">搜索</button>
    </form>

    <div class="navbar-actions">
      <div
        class="menu-links"
        id="nav-drawer"
        role="navigation"
        aria-label="页面导航"
      >
        {
          navItems.map((item) => {
            const active = isActive(item.href);
            return (
              <a
                href={item.href}
                class={active ? 'active' : ''}
                aria-current={active ? 'page' : undefined}
              >
                {item.label}
              </a>
            );
          })
        }
      </div>

      <ThemeToggles />

      <button
        type="button"
        class="nav-toggle"
        id="nav-toggle"
        aria-label="打开菜单"
        aria-expanded="false"
        aria-controls="nav-drawer"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  import '../scripts/navbar.js';
</script>
