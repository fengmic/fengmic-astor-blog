---
interface Props {
  images: string[];
  tags: string[];
}

const { images, tags } = Astro.props as Props;
const TRANSPARENT_PIXEL = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==';
---

<aside class="right-sidebar" aria-label="侧边栏工具">
  <section class="glass-panel widget carousel-widget" aria-label="图片轮播">
    <h3>图片轮播</h3>
    <div class="carousel" data-carousel aria-label="轮播图片展示">
      {
        images.length > 0 ? (
          images.map((url, idx) => (
            <img
              class={idx === 0 ? 'active' : ''}
              src={idx === 0 ? url : TRANSPARENT_PIXEL}
              data-src={idx === 0 ? undefined : url}
              alt="轮播图片"
              loading={idx === 0 ? 'eager' : 'lazy'}
              decoding="async"
            />
          ))
        ) : (
          <div class="emoji-fallback" aria-hidden="true">🌸</div>
        )
      }
    </div>
  </section>

  <section class="glass-panel widget calendar-widget" aria-label="动漫日历">
    <div id="calendar-root" class="calendar-root"></div>
  </section>

  <section class="glass-panel widget" aria-label="标签归档">
    <h3>标签归档</h3>
    <div class="tag-list" role="group" aria-label="按标签筛选">
      {
        tags.map((tag) => (
          <button class="tag-chip" data-tag-filter={tag} aria-pressed="false">#{tag}</button>
        ))
      }
    </div>
  </section>
</aside>

<script>
  import '../scripts/right-sidebar.js';
</script>
