---
import { format } from 'date-fns';
import { zhCN } from 'date-fns/locale';
import { getPostSlug, type BlogPost } from '../utils/blog';

const { post } = Astro.props as { post: BlogPost };
const postSlug = getPostSlug(post);
const monthAnchor = `archive-${format(post.data.date, 'yyyy-MM')}`;
const dateLabel = format(post.data.date, 'yyyy-MM-dd', { locale: zhCN });
const dateIso = format(post.data.date, 'yyyy-MM-dd');
---

<article
  class="post-card glass-panel"
  data-post-card
  data-tags={post.data.tags.join('|').toLowerCase()}
  data-search={`${post.data.title} ${post.data.excerpt} ${post.data.tags.join(' ')}`.toLowerCase()}
>
  {post.data.cover && (
    <div class="post-card-cover" aria-hidden="true">
      <img src={post.data.cover} alt="" width="800" height="450" loading="lazy" decoding="async" fetchpriority="low" />
    </div>
  )}

  <h3>
    <a class="post-card-title-link" href={`/post/${postSlug}`}>{post.data.title}</a>
  </h3>
  <p>{post.data.excerpt}</p>

  <div class="post-meta">
    <span>
      <a class="post-meta-link author-name" href="/home" aria-label={`查看作者 ${post.data.author} 的主页`}>
        {post.data.author}
      </a>
    </span>
    <span>
      <a
        class="post-meta-link post-meta-date"
        href={`/archive?mode=time#${monthAnchor}`}
        aria-label={`查看 ${format(post.data.date, 'yyyy 年 MM 月')} 的归档`}
      >
        <svg class="meta-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <rect x="3" y="4" width="18" height="18" rx="2" />
          <path d="M16 2v4M8 2v4M3 10h18" />
        </svg>
        <time datetime={dateIso}>{dateLabel}</time>
      </a>
    </span>
  </div>

  <div class="post-tags">
    {post.data.tags.map((tag: string) => (
      <a class="post-tag-link" href={`/archive?mode=tag&tag=${encodeURIComponent(tag)}`}>#{tag}</a>
    ))}
  </div>
</article>
