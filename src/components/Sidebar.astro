---
interface UserInfo {
  name: string;
  avatar: string;
  bio: string;
  email?: string;
  qq?: string;
  github?: string;
  motto?: string;
}

const { userInfo } = Astro.props as { userInfo: UserInfo };
---

<aside class="glass-panel sidebar" aria-label="个人信息">
  <div class="avatar-wrap">
    {
      userInfo.avatar?.startsWith('http') ? (
        <img src={userInfo.avatar} alt={`${userInfo.name} 的头像`} loading="lazy" width="110" height="110" decoding="async" />
      ) : (
        <div class="avatar-emoji" role="img" aria-label={userInfo.name}>{userInfo.avatar || '🌸'}</div>
      )
    }
  </div>

  <h2>{userInfo.name}</h2>
  <p class="bio">{userInfo.bio}</p>

  <div class="split-line" aria-hidden="true"></div>

  <div class="info-list">
    {userInfo.email && (
      <p>
        <svg class="info-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <path d="m3 7 9 6 9-6" />
        </svg>
        <a href={`mailto:${userInfo.email}`}>{userInfo.email}</a>
      </p>
    )}
    {userInfo.qq && (
      <p>
        <svg class="info-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
        </svg>
        <span>{userInfo.qq}</span>
      </p>
    )}
    {userInfo.github && (
      <p>
        <svg class="info-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
        </svg>
        <a href={userInfo.github.startsWith('http') ? userInfo.github : `https://${userInfo.github}`} target="_blank" rel="noreferrer noopener">{userInfo.github}</a>
      </p>
    )}
  </div>

  {userInfo.motto && (
    <blockquote>
      {userInfo.motto}
    </blockquote>
  )}
</aside>
