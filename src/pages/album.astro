---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import BackgroundLayer from '../components/BackgroundLayer.astro';
import albumsData from '../data/albums.json';
import configData from '../data/config.json';

const albums = albumsData.albums || [];
const albumColumns = Math.max(1, Math.floor(Number(configData?.albumLayout?.columns) || 3));
const TRANSPARENT_PIXEL = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==';
---

<MainLayout title="相册 | 楓念的博客" description="楓念的相册，记录生活中的美好瞬间">
  <BackgroundLayer />
  <Navbar currentPath="/album" />

  <main class="page-wrap single-column" id="main-content">
    <section class="glass-panel category-head">
      <h1>相册</h1>
      <p>共 {albums.length} 张图片</p>
    </section>

    <section
      class="album-wall"
      id="album-wall"
      role="list"
      aria-label="相册图片列表"
      data-columns={albumColumns}
      style={`--album-columns:${albumColumns};--album-gap-x:14px;--album-gap-y:0px;`}
    >
      {
        albums.map((album, idx) => (
          <article
            class="glass-panel album-item"
            role="listitem"
            data-image={album.imageUrl}
            data-desc={album.description}
            data-date={album.createdAt}
            tabindex="0"
            aria-label={`图片：${album.description}`}
            data-index={idx}
          >
            <img
              src={TRANSPARENT_PIXEL}
              data-src={album.imageUrl}
              data-loaded="false"
              alt={album.description}
              decoding="async"
            />
            <div class="album-meta">
              <p>{album.description}</p>
              <time datetime={album.createdAt}>{album.createdAt}</time>
            </div>
          </article>
        ))
      }
    </section>
  </main>

  <div id="album-modal" class="album-modal hidden" role="dialog" aria-label="图片预览" aria-hidden="true">
    <div class="album-modal-inner glass-panel">
      <button id="close-modal" aria-label="关闭预览">x</button>
      <img id="modal-image" src="" alt="预览图" />
      <p id="modal-desc"></p>
      <time id="modal-date"></time>
    </div>
  </div>

  <script is:inline>
    const wall = document.getElementById('album-wall');
    const modal = document.getElementById('album-modal');
    const closeBtn = document.getElementById('close-modal');
    const image = document.getElementById('modal-image');
    const desc = document.getElementById('modal-desc');
    const date = document.getElementById('modal-date');
    const BREAKPOINT_TABLET = 1080;
    const BREAKPOINT_MOBILE = 640;

    let layoutRafId = 0;
    let lazyObserver = null;
    let lazyLoaderInitialized = false;

    function getEffectiveColumns(configuredColumns) {
      if (window.innerWidth <= BREAKPOINT_MOBILE) return 1;
      if (window.innerWidth <= BREAKPOINT_TABLET) return Math.min(2, configuredColumns);
      return configuredColumns;
    }

    function scheduleMasonryLayout() {
      cancelAnimationFrame(layoutRafId);
      layoutRafId = requestAnimationFrame(applyMasonryLayout);
    }

    function loadImageIfNeeded(img) {
      if (!(img instanceof HTMLImageElement)) return;
      if (img.dataset.loaded === 'true' || img.dataset.loading === 'true') return;

      const realSrc = img.dataset.src;
      if (!realSrc) return;

      img.dataset.loading = 'true';
      img.src = realSrc;
    }

    function initViewportLazyLoader() {
      if (!(wall instanceof HTMLElement) || lazyLoaderInitialized) return;
      lazyLoaderInitialized = true;

      const items = Array.from(wall.querySelectorAll('.album-item')).filter((item) => item instanceof HTMLElement);
      const configuredColumns = Math.max(1, Number(wall.dataset.columns || 3));
      const eagerCount = Math.min(items.length, getEffectiveColumns(configuredColumns) * 2);

      // Ensure first visible rows are available immediately.
      items.slice(0, eagerCount).forEach((item) => {
        const img = item.querySelector('img');
        loadImageIfNeeded(img);
      });

      if ('IntersectionObserver' in window) {
        lazyObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            const item = entry.target;
            if (!(item instanceof HTMLElement)) return;
            const img = item.querySelector('img');

            loadImageIfNeeded(img);
            lazyObserver?.unobserve(item);
          });
        }, {
          root: null,
          rootMargin: '200px 0px',
          threshold: 0.01,
        });

        items.forEach((item) => lazyObserver?.observe(item));
      } else {
        // Fallback for older browsers: eagerly load all images.
        wall.querySelectorAll('img').forEach((img) => loadImageIfNeeded(img));
      }

      // Safety net: if observer does not trigger in time, load a first batch.
      window.setTimeout(() => {
        const loadedCount = wall.querySelectorAll('img[data-loaded="true"]').length;
        if (loadedCount > 0) return;

        items.slice(0, Math.min(items.length, 8)).forEach((item) => {
          const img = item.querySelector('img');
          loadImageIfNeeded(img);
        });
      }, 800);
    }

    function applyMasonryLayout() {
      if (!(wall instanceof HTMLElement)) return;

      const items = Array.from(wall.querySelectorAll('.album-item')).filter((item) => item instanceof HTMLElement);
      if (!items.length) {
        wall.style.height = '';
        return;
      }

      const computed = getComputedStyle(wall);
      const configuredColumns = Math.max(1, Number(wall.dataset.columns || 3));
      const columns = getEffectiveColumns(configuredColumns);
      const gapX = Number.parseFloat(computed.getPropertyValue('--album-gap-x')) || 14;
      const gapY = Number.parseFloat(computed.getPropertyValue('--album-gap-y')) || 0;
      const containerWidth = wall.clientWidth;
      const itemWidth = (containerWidth - gapX * (columns - 1)) / columns;

      if (!(itemWidth > 0)) return;

      const columnHeights = new Array(columns).fill(0);

      items.forEach((item) => {
        item.style.width = `${itemWidth}px`;

        let targetColumn = 0;
        for (let i = 1; i < columnHeights.length; i++) {
          if (columnHeights[i] < columnHeights[targetColumn]) {
            targetColumn = i;
          }
        }

        const left = targetColumn * (itemWidth + gapX);
        const top = columnHeights[targetColumn];

        item.style.left = `${left}px`;
        item.style.top = `${top}px`;

        columnHeights[targetColumn] += item.offsetHeight + gapY;
      });

      const maxHeight = Math.max(...columnHeights);
      wall.style.height = `${Math.max(0, maxHeight - gapY)}px`;

      // Start viewport lazy loading only after first stable layout.
      if (!lazyLoaderInitialized) {
        initViewportLazyLoader();
      }
    }

    function openModal(url, text, createdAt) {
      if (image instanceof HTMLImageElement) {
        image.src = url;
        image.alt = text;
      }
      if (desc) desc.textContent = text;
      if (date) {
        date.textContent = createdAt;
        date.setAttribute('datetime', createdAt);
      }
      modal?.classList.remove('hidden');
      modal?.setAttribute('aria-hidden', 'false');
      closeBtn?.focus();
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal?.classList.add('hidden');
      modal?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      const lastFocused = document.querySelector('.album-item:focus-within');
      if (lastFocused instanceof HTMLElement) lastFocused.focus();
    }

    wall?.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const item = target.closest('.album-item');
      if (!(item instanceof HTMLElement)) return;

      const url = item.dataset.image || '';
      const text = item.dataset.desc || '';
      const createdAt = item.dataset.date || '';
      openModal(url, text, createdAt);
    });

    // Re-layout when image dimensions are available or viewport changes.
    wall?.querySelectorAll('img').forEach((img) => {
      img.addEventListener('load', () => {
        img.dataset.loaded = 'true';
        delete img.dataset.loading;
        scheduleMasonryLayout();
      });
      img.addEventListener('error', () => {
        delete img.dataset.loading;
        scheduleMasonryLayout();
      });
    });

    // Initialize lazy loader before the first layout pass.
    initViewportLazyLoader();

    window.addEventListener('resize', scheduleMasonryLayout);

    // Initial layout pass.
    scheduleMasonryLayout();

    // Keyboard: Enter/Space on album item
    wall?.addEventListener('keydown', (event) => {
      if (!(event instanceof KeyboardEvent)) return;
      if (event.key !== 'Enter' && event.key !== ' ') return;
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const item = target.closest('.album-item');
      if (!(item instanceof HTMLElement)) return;

      event.preventDefault();
      const url = item.dataset.image || '';
      const text = item.dataset.desc || '';
      const createdAt = item.dataset.date || '';
      openModal(url, text, createdAt);
    });

    closeBtn?.addEventListener('click', () => closeModal());

    modal?.addEventListener('click', (event) => {
      if (event.target === modal) {
        closeModal();
      }
    });

    // Keyboard: ESC to close
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });
  </script>
</MainLayout>
