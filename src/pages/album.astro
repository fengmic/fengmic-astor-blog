---
import '../styles/album.css';
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import BackgroundLayer from '../components/BackgroundLayer.astro';
import albumsData from '../data/albums.json';
import configData from '../data/config.json';

const albums = albumsData.albums || [];
const albumColumns = Math.max(1, Math.floor(Number(configData?.albumLayout?.columns) || 3));

function getAlbumThumbnailUrl(album: { thumbnailUrl?: string; imageUrl?: string }) {
  if (album?.thumbnailUrl) return album.thumbnailUrl;

  if (typeof album?.imageUrl === 'string') {
    return album.imageUrl.replace(/(\.[a-zA-Z0-9]+)(?=\?|$)/, '.th$1');
  }

  return '';
}
---

<MainLayout title="相册 | 楓念的博客" description="楓念的相册，记录生活中的美好瞬间">
  <BackgroundLayer />
  <Navbar />

  <main class="page-wrap single-column" id="main-content">
    <section
      class="album-wall"
      id="album-wall"
      role="list"
      aria-label="相册图片列表"
      data-columns={albumColumns}
      style={`--album-columns:${albumColumns};--album-gap-x:14px;--album-gap-y:0px;`}
    >
      {
        albums.map((album) => (
          <article
            class="glass-panel album-item"
            role="listitem"
            data-image={album.imageUrl}
            data-thumb={getAlbumThumbnailUrl(album)}
            data-desc={album.description}
            data-date={album.createdAt}
            tabindex="0"
            aria-label={`图片：${album.description}`}
          >
            <img
              src={getAlbumThumbnailUrl(album)}
              data-src={album.imageUrl}
              alt={album.description}
              loading="lazy"
              decoding="async"
              style="width:100%;height:auto;display:block;"
            />
            <div class="album-meta">
              <p>{album.description}</p>
              <time datetime={album.createdAt}>{album.createdAt}</time>
            </div>
          </article>
        ))
      }
    </section>
  </main>

  <div id="album-modal" class="album-modal hidden" role="dialog" aria-label="图片预览" aria-hidden="true">
    <div class="album-modal-inner glass-panel">
      <button id="close-modal" aria-label="关闭预览">x</button>
      <figure class="modal-figure">
        <img id="modal-image" src="" alt="预览图" />
        <figcaption class="modal-caption">
          <p id="modal-desc"></p>
          <time id="modal-date"></time>
        </figcaption>
      </figure>
    </div>
  </div>

  <script>
    import '../scripts/album.js';
  </script>
</MainLayout>
