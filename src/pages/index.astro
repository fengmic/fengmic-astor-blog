---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="欢迎来到楓念的博客">
  <main class="splash-screen">
    <div class="starfield"></div>
    <div class="splash-content">
      <h1>欢迎来到 楓念 的博客</h1>
      <p>Welcome to Fengmic's Blog</p>
      <p class="splash-hint">正在跳转…</p>
    </div>
  </main>

  <script is:inline>
    setTimeout(() => {
      window.location.href = '/home';
    }, 1500);
  </script>
</MainLayout>
