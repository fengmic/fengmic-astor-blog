---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import BackgroundLayer from '../components/BackgroundLayer.astro';
import { getAllTags, getPostSlug, sortPostsByDate } from '../utils/blog';

const posts = sortPostsByDate(await getCollection('posts'));
const tags = getAllTags(posts);
---

<MainLayout title="分类 | 楓念的博客">
  <BackgroundLayer />
  <Navbar currentPath="/category" />

  <main class="page-wrap single-column" id="main-content">
    <section class="glass-panel category-head">
      <h1>文章分类</h1>
      <p>共 {tags.length} 个分类，{posts.length} 篇文章</p>
    </section>

    <section class="category-grid">
      {
        tags.map((item) => (
          <article class="glass-panel category-card">
            <header>
              <h2>#{item.tag}</h2>
              <span>{item.count} 篇</span>
            </header>
            <ul>
              {posts.filter((p) => p.data.tags.includes(item.tag)).slice(0, 4).map((post) => (
                <li><a href={`/post/${getPostSlug(post)}`}>{post.data.title}</a></li>
              ))}
            </ul>
          </article>
        ))
      }
    </section>
  </main>
</MainLayout>
